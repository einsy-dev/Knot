{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "version": "0.0.2",
  "name": "Knot",
  "description": "Knot is a powerful tool that connects your local applications and the browser. By establishing a secure, high-speed connection.",
  "permissions": ["tabs", "activeTab", "scripting"],
  "icons": {
    "16": "images/16x16.png",
    "32": "images/32x32.png",
    "48": "images/48x48.png",
    "64": "images/64x64.png",
    "128": "images/128x128.png"
  },
  "background": {
    "service_worker": "./background/main.ts"
  },
  "action": {
    "default_popup": "./popup/index.html"
  },
  "author": "Einsy"
}
